# OpenAI API Key (required)
OPENAI_API_KEY=your-api-key-here

# Global hotkey to toggle recording
HOTKEY=ctrl+shift+space

# Whisper model
MODEL=whisper-1

# Language hint: auto, en, hi, etc.
LANGUAGE=auto

# GPT-4o text cleanup
CLEANUP_ENABLED=true
CLEANUP_MODEL=gpt-4o

# Output mode: type (auto-type at cursor) or clipboard
OUTPUT_MODE=type

# Silence detection: seconds of silence before auto-stop
SILENCE_THRESHOLD=2.0

# Audio sample rate
SAMPLE_RATE=16000
