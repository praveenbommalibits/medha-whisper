# Global hotkey to toggle recording
HOTKEY=ctrl+shift+space

# Whisper model size: tiny, base, small, medium, large-v3
# tiny=75MB fastest | base=140MB | small=460MB good balance | medium=1.5GB | large-v3=3GB best accuracy
WHISPER_MODEL=small

# Language hint: auto, en, hi, etc.
LANGUAGE=auto

# Text cleanup via Ollama (free, local). Set to false to disable.
CLEANUP_ENABLED=false
CLEANUP_MODEL=llama3.2

# Output mode: type (auto-type at cursor) or clipboard
OUTPUT_MODE=type

# Silence detection: seconds of silence before auto-stop
SILENCE_THRESHOLD=2.0

# Audio sample rate
SAMPLE_RATE=16000
